# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
.env
.env.*
!.env.example

# Packaging / build
*.egg-info/
.eggs/
dist/
build/

# Test / type / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/

# Logs / local artifacts
*.log

# ML / experiment artifacts
*.pt
*.pth
*.ckpt
*.onnx
*.tflite
*.npz
*.npy
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib

# TensorBoard / W&B / Lightning-style outputs (always local)
**/events.out.tfevents.*
wandb/
lightning_logs/

# Datasets & caches (keep directory placeholders only)
data/**/*
!data/**/.gitkeep

# Experiment outputs (keep empty tree in git)
experiment/runs/**
!experiment/runs/.gitkeep

# Legacy extract_audio: track only CSS/ (ignore F0_*, genuine, Train, etc.)
extract_audio/*
!extract_audio/CSS/
!extract_audio/CSS/**
